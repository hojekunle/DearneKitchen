# Local development only. On Render, set these in the Web Service → Environment tab.
# Do not commit real production secrets to git.

SECRET_KEY=django-insecure-local-dev-key-change-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Required on Render after deploy (use your real Render URL):
# CSRF_TRUSTED_ORIGINS=https://your-app-name.onrender.com

# Local dev uses SQLite. On Render, paste the PostgreSQL Internal Database URL:
# DATABASE_URL=postgresql://dearnekitchen_user:password@dpg-xxxxx-a/dearnekitchen

# Email (Mailtrap sandbox for local testing)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=hello@demomailtrap.co
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_HOST_USER=4a5dccde671896
EMAIL_HOST_PASSWORD=c7b98f8e9261ab
EMAIL_PORT=2525
EMAIL_USE_TLS=True

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAX_DAILY_BOOKING_CAPACITY=50
ENABLE_CSP=True
